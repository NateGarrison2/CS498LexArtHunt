<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LexArtHunt.DetailsPage"
             Title="Artwork Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame CornerRadius="10" Padding="0" IsClippedToBounds="True" HeightRequest="300">
                <Image x:Name="ArtImage" Aspect="AspectFill" />
            </Frame>

            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
            <Label x:Name="ArtistLabel" FontSize="18" FontAttributes="Italic" TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="History &amp; Description" FontSize="14" FontAttributes="Bold" />
            <Label x:Name="DescriptionLabel" FontSize="16" LineBreakMode="WordWrap" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Year:" FontAttributes="Bold" />
                <Label x:Name="YearLabel" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>