<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="LexArtHunt.MainPage"
             Title="Lexington Art Hunt"
             BackgroundColor="#FF0088EE">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Collection"
                     Order="Primary"
                     Clicked="OnViewCollectionClicked" />
    </ContentPage.ToolbarItems>

    <Grid>

        <mapsui:MapView x:Name="ArtMap"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        IsZoomButtonVisible="True"
                        IsNorthingButtonVisible="True"
                        IsMyLocationButtonVisible="False"/>

        <Border x:Name="FilterPill"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,24"
                Padding="20,10"
                BackgroundColor="White"
                Stroke="LightGray"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20" />
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnFilterPillTapped" />
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="8">
                <Label x:Name="FilterPillLabel"
                       Text="Filter: All"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="Navy"/>
                <Label x:Name="FilterChevron"
                       Text="^"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="LightBlue"/>
            </HorizontalStackLayout>
        </Border>

        <!-- Drawer overlay (tap outside to dismiss) -->
        <BoxView x:Name="DrawerScrim"
                 BackgroundColor="#66000000"
                 IsVisible="False"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnScrimTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Bottom drawer -->
        <Grid x:Name="FilterDrawer"
              VerticalOptions="End"
              HorizontalOptions="Fill"
              TranslationY="400">
            <Border Padding="0,0,0,12"
                    BackgroundColor="White"
                    Stroke="#EEEEEE"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16,16,0,0" />
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <!-- Handle -->
                    <BoxView WidthRequest="36"
                             HeightRequest="4"
                             Color="#CCCCCC"
                             HorizontalOptions="Center"
                             Margin="0,10,0,12">
                        <BoxView.Clip>
                            <RoundRectangleGeometry CornerRadius="2" Rect="0,0,36,4" />
                        </BoxView.Clip>
                    </BoxView>

                    <!-- Title -->
                    <Label Text="CATEGORY"
                           FontSize="11"
                           TextColor="#888888"
                           FontAttributes="Bold"
                           Margin="16,0,16,8" />

                    <!-- Scrollable category list -->
                    <ScrollView MaximumHeightRequest="320">
                        <VerticalStackLayout x:Name="CategoryList" Spacing="0" />
                    </ScrollView>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>